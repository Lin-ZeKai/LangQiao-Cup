```cpp`
#include <iostream>   // 输入输出流头文件，用于 cin、cout
#include <string>     // 字符串类头文件，用于 string 类型
#include <algorithm>  // 算法头文件，用于 reverse 函数
using namespace std;  // 使用标准命名空间，避免每次写 std::

// 函数：将一个用字符串表示的大整数乘以 2，返回结果字符串
string mul2(const string& s) {
    string res;          // 存放结果的字符串（初始为空）
    int carry = 0;       // 进位，初始为0
    // 从原数字的最低位（字符串末尾）开始遍历
    for (int i = s.size() - 1; i >= 0; --i) {
        int digit = s[i] - '0';      // 当前字符转数字，'3' - '0' = 3
        int prod = digit * 2 + carry; // 当前位乘以2再加上进位
        res.push_back(prod % 10 + '0'); // 将结果的个位转为字符并加入res末尾
        carry = prod / 10;             // 更新进位（十位数字）
    }
    // 循环结束后如果还有进位，例如 5*2=10，最后carry=1，需要加到最高位
    if (carry) res.push_back(carry + '0'); // 将进位字符加入
    // 因为我们是倒着计算的（从低位到高位），所以res现在是逆序的
    // 例如 s="123" 计算过程：3*2=6 → res="6"；2*2=4 → res="64"；1*2=2 → res="642"；最后需要反转
    reverse(res.begin(), res.end()); // 反转得到正确顺序 "246"
    return res; // 返回乘以2后的字符串
}

// 函数：去除字符串前导的 '0'，若全为0则返回 "0"
string trim(const string& s) {
    int i = 0; // 从第一个字符开始扫描
    // 跳过所有连续的 '0'
    while (i < s.size() && s[i] == '0') ++i;
    // 如果跳过了所有字符（即原串全是0），返回 "0"
    if (i == s.size()) return "0";
    // 否则返回从第一个非零字符开始的子串
    return s.substr(i);
}

// 函数：给一个已经去除前导0的大整数加1，返回结果
// 输入 s 保证没有前导0（除非 s="0"）
string addOne(string s) {
    // 从最低位（字符串末尾）开始处理进位
    int i = s.size() - 1;
    // 当遇到 '9' 时，需要进位，将其变为 '0'，继续向左检查
    while (i >= 0 && s[i] == '9') {
        s[i] = '0';      // 该位变0
        --i;             // 移动到前一位
    }
    // 如果 i < 0，说明所有位都是9，例如 "999" +1 = "1000"
    if (i < 0) {
        s = "1" + s;     // 在最前面加 '1'
    } else {
        // 否则，当前位不是9，直接加1（因为字符数字加1，例如 '3'+1 = '4'）
        s[i] += 1;
    }
    return s;
}

int main() {
    int n;          // 转换参数 n
    string d;       // 输入的浮点数，用字符串存储以保证精度
    cin >> n >> d;  // 从标准输入读取 n 和 d

    // ---------- 分离整数部分和小数部分 ----------
    size_t pos = d.find('.');          // 查找小数点的位置
    string int_part = d.substr(0, pos); // 小数点之前的是整数部分，如 "3"
    string frac_part = d.substr(pos + 1); // 小数点之后的是小数部分，如 "14"
    if (int_part.empty()) int_part = "0"; // 如果整数部分为空（例如 .5），补 "0"
    int k = frac_part.size();           // 小数位数 k，例如 2

    // ---------- 去掉小数点，合并成整数 ----------
    // 例如 "3.14" → int_part="3", frac_part="14" → num="314"
    string num = int_part + frac_part;

    // ---------- 乘以 2^n ----------
    string M = num;                     // 当前大整数，初始为 num
    for (int i = 0; i < n; ++i) {       // 连续乘以 2 共 n 次
        M = mul2(M);                    // 每次调用 mul2 完成乘2
    }

    // ---------- 处理没有小数部分的情况（k==0） ----------
    if (k == 0) {
        cout << trim(M) << endl;        // 直接输出，去掉前导0
        return 0;                       // 结束程序
    }

    // ---------- 分离整数部分和小数部分 ----------
    int len = M.size();                  // 当前大整数 M 的总位数
    string int_str, frac_str;             // 分别存储整数部分字符串和小数部分字符串
    if (len <= k) {                       // 如果 M 位数小于等于小数位数，说明整数部分为0
        int_str = "0";                    // 整数部分为 "0"
        // 小数部分需要在前面补0，使长度等于 k
        // 例如 M="12", k=3 → 小数部分应为 "012"（因为原数实际是 0.012）
        frac_str = string(k - len, '0') + M;
    } else {
        // 整数部分 = M 的前 len-k 位
        int_str = M.substr(0, len - k);
        // 小数部分 = M 的后 k 位
        frac_str = M.substr(len - k);
    }

    // ---------- 去掉整数部分的前导0 ----------
    int_str = trim(int_str);   // 例如 "0012" → "12"，但 "0" 会保留为 "0"

    // ---------- 构造四舍五入的阈值 ----------
    // 阈值 = 5 * 10^(k-1)，即字符串 "5" + k-1 个 "0"
    // 例如 k=2 → 阈值 = "50"；k=3 → 阈值 = "500"
    string threshold = "5" + string(k - 1, '0');

    // ---------- 判断是否要进位 ----------
    // 将小数部分与阈值比较（字符串字典序比较）
    // 注意：两个字符串长度相同（因为阈值长度为k，小数部分也通过补0保证了长度为k）
    // 字符串比较规则：从左到右比较每个字符的ASCII码，恰好符合数值比较
    // 例如 "50" > "49" 为 true，因为 '5' > '4'；"50" == "50" 为 true
    if (frac_str >= threshold) {
        // 如果需要进位，给整数部分加1
        int_str = addOne(int_str);
    }

    // ---------- 输出最终整数部分 ----------
    cout << int_str << endl;

    return 0; // 程序正常结束
}
